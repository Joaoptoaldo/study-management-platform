<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Importa as definições padrão do Spring Boot -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- 1. Perfil de Desenvolvimento (local/default): Console colorido legível por humanos -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <!-- Incluímos [%X{traceId}] no padrão de log para exibir o correlation ID em amarelo -->
                <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %clr([%X{traceId}]){yellow} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        
        <!-- Logs detalhados do nosso sistema de estudos -->
        <logger name="com.studyplatform" level="DEBUG" />
        <logger name="org.springframework.security" level="DEBUG" />
    </springProfile>

    <!-- 2. Perfil de Produção (prod): Logs estruturados em formato JSON para ingestão de dados -->
    <springProfile name="prod">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <timeZone>UTC</timeZone>
                    </timestamp>
                    <pattern>
                        <pattern>
                            {
                            "timestamp": "%date{yyyy-MM-dd'T'HH:mm:ss.SSS'Z',UTC}",
                            "severity": "%level",
                            "service": "study-management-platform",
                            "traceId": "%mdc{traceId}",
                            "thread": "%thread",
                            "logger": "%logger",
                            "message": "%message",
                            "stack_trace": "%exception"
                            }
                        </pattern>
                    </pattern>
                </providers>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

</configuration>
