# Porta do Servidor Backend
SERVER_PORT=8080

# Banco de Dados MySQL (Configurado para criar o schema local automaticamente se não existir)
DB_URL=jdbc:mysql://localhost:3306/studyplatform?createDatabaseIfNotExist=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=sua_senha_aqui

# Segurança (JWT) - Chave secreta de no mínimo 32 caracteres (Gere uma chave segura)
# Não compartilhe chaves de produção nem as envie para repositórios públicos
JWT_SECRET=sua_chave_secreta_com_pelo_menos_32_caracteres
JWT_EXPIRATION=86400000

# CORS Origins Permitidas (Portas padrão do frontend Vite/React)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
